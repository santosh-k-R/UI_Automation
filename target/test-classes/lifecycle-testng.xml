<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="LifeCycle" verbose="2" configfailurepolicy="continue">
    <test name="LifeCycleTests" parallel="methods" thread-count="40">
        <groups>
            <run>
                <exclude name="singleThread"/>
            </run>
        </groups>
        <classes>
            <class name="com.cisco.tests.lifecycle.AcceleratorsPageIT"/>
            <class name="com.cisco.tests.lifecycle.AskTheExpertsPageIT"/>
            <class name="com.cisco.tests.lifecycle.RaceTrackPageIT"/>
            <class name="com.cisco.tests.lifecycle.SuccessTipsPageIT"/>
            <class name="com.cisco.tests.lifecycle.LearningPageIT"/>
            <class name="com.cisco.tests.lifecycle.CiscoCommunityPageIT"/>
            <class name="com.cisco.tests.lifecycle.LifecyclePageIT"/>
        </classes>
    </test>
    <test name="singleThreadTest" parallel="classes" thread-count="7">
        <groups>
            <run>
                <include name="singleThread"/>
            </run>
        </groups>
        <classes>
            <class name="com.cisco.tests.lifecycle.AcceleratorsPageIT"/>
            <class name="com.cisco.tests.lifecycle.AskTheExpertsPageIT"/>
            <class name="com.cisco.tests.lifecycle.RaceTrackPageIT"/>
            <class name="com.cisco.tests.lifecycle.SuccessTipsPageIT"/>
            <class name="com.cisco.tests.lifecycle.LearningPageIT"/>
            <class name="com.cisco.tests.lifecycle.CiscoCommunityPageIT"/>
            <class name="com.cisco.tests.lifecycle.LifecyclePageIT"/>
        </classes>
    </test>
</suite>
